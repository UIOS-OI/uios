# Provider-neutral AI gateway
UIOS_AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/chat/completions
UIOS_AI_GATEWAY_KEY=
UIOS_DEFAULT_MODEL=
UIOS_ROUTING_STRATEGY=explicit
UIOS_FALLBACK_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
UIOS_FALLBACK_GATEWAY_KEY=
UIOS_FALLBACK_DEFAULT_MODEL=

# Built-in Aegis security plane
UIOS_AEGIS_URL=
UIOS_AEGIS_KEY=
UIOS_AEGIS_REQUIRED=false
UIOS_AEGIS_FAIL_CLOSED=true

# Workspace metering
UIOS_WORKSPACE_SECRET=replace-with-a-long-random-secret
UIOS_PLAN_LIMIT_UNITS=1000
UIOS_SCALE_PLAN_LIMIT_UNITS=25000
UIOS_ENTERPRISE_PLAN_LIMIT_UNITS=10000000
UIOS_RATE_LIMIT_PER_MINUTE=30
UIOS_STATE_FILE=.uios-data/state.json
UIOS_STATE_DB=.uios-data/uios.sqlite
UIOS_AUDIT_RETENTION_DAYS=365

# Stripe monetization
STRIPE_SECRET_KEY=
STRIPE_PRICE_SCALE=
STRIPE_WEBHOOK_SECRET=

# Public security disclosure metadata
UIOS_SECURITY_CONTACT=mailto:security@yourdomain.example
UIOS_SECURITY_POLICY_URL=/security
