{
  "name": "uios",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.34.2",
  "scripts": {
    "dev": "pnpm --filter @uios/dashboard dev",
    "build": "pnpm --filter @uios/dashboard build",
    "start": "pnpm --filter @uios/dashboard start",
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "typecheck": "pnpm --filter @uios/dashboard typecheck",
    "smoke": "node scripts/smoke.mjs",
    "provider-smoke": "node scripts/provider-smoke.mjs",
    "test:e2e": "node scripts/e2e-tests.mjs",
    "launch-audit": "node scripts/launch-audit.mjs",
    "security-scan": "node scripts/security-scan.mjs"
  }
}
